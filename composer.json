{
  "name": "laravel/laravel",
  "config": {
    "preferred-install": "dist",
    "sort-packages": true,
    "optimize-autoloader": true,
    "platform": {
      "php": "8.4"
    },
    "allow-plugins": {
      "symfony/thanks": false,
      "php-http/discovery": true,
      "pestphp/pest-plugin": true
    },
    "audit": {
      "ignore": {
        "PKSA-y2cr-5h3j-g3ys": "firebase/php-jwt <7.0.0 weak encryption (CVE-2025-45769); pinned by packbackbooks/lti-1p3-tool fork to ^6.0",
        "PKSA-2kqm-ps5x-s4f5": "firebase/php-jwt; pinned by packbackbooks/lti-1p3-tool fork"
      }
    }
  },
  "description": "The Laravel Framework.",
  "keywords": [
    "framework",
    "laravel"
  ],
  "license": "MIT",
  "type": "project",
  "repositories": [
    {
      "type": "vcs",
      "url": "https://github.com/UMN-LATIS/laravel-shibboleth"
    },
    {
      "type": "git",
      "url": "https://github.com/UMN-LATIS/LTI-Tool-Provider-Library-PHP"
    },
    {
      "type": "vcs",
      "url": "https://github.com/cmcfadden/lti-1-3-php-library"
    },
    {
      "type": "composer",
      "url": "https://nova.laravel.com"
    }
  ],
  "require": {
    "php": "^8.4",
    "dyrynda/laravel-cascade-soft-deletes": "^4.1",
    "fakerphp/faker": "^1.19",
    "imsglobal/lti": "dev-master",
    "intervention/image": "^4.0",
    "laravel/framework": "^13.0",
    "laravel/helpers": "^1.4",
    "laravel/nova": "^5.8",
    "laravel/reverb": "^1.10",
    "laravel/tinker": "^3.0",
    "orangehill/iseed": "^3.0",
    "packbackbooks/lti-1p3-tool": "dev-upstream-merge-2",
    "razorbacks/laravel-shibboleth": "dev-umn",
    "sentry/sentry-laravel": "^4.25",
    "symfony/http-client": "^8.0",
    "symfony/mailgun-mailer": "^8.0",
    "yadahan/laravel-authentication-log": "^1.3"
  },
  "require-dev": {
    "barryvdh/laravel-debugbar": "^4.2",
    "barryvdh/laravel-ide-helper": "^3.0",
    "deployer/deployer": "^7.0",
    "filp/whoops": "~2.0",
    "laracasts/cypress": "^3.0.4",
    "laravel/sail": "^1.58",
    "mockery/mockery": "~1.0",
    "nunomaduro/collision": "^8.0",
    "pestphp/pest": "^4.4",
    "phpunit/phpunit": "^12.0",
    "spatie/laravel-ignition": "^2.0",
    "symfony/thanks": "^1.0"
  },
  "autoload": {
    "psr-4": {
      "App\\": "app/",
      "Database\\Factories\\": "database/factories/",
      "Database\\Seeders\\": "database/seeders/"
    },
    "files": [
      "app/constants.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "dont-discover": []
    }
  },
  "scripts": {
    "post-root-package-install": [
      "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
    ],
    "post-create-project-cmd": [
      "@php artisan key:generate"
    ],
    "post-autoload-dump": [
      "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
      "@php artisan package:discover"
    ],
    "post-update-cmd": [
      "Illuminate\\Foundation\\ComposerScripts::postUpdate",
      "@php artisan ide-helper:generate"
    ]
  },
  "minimum-stability": "stable",
  "prefer-stable": true
}
